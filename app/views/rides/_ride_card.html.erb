<div id="<%= dom_id(ride) %>" class="border-b border-gray-200">
  <div class="py-4">
    <%= link_to dashboard_expand_ride_path(ride_id: ride.id, expanded: params[:expanded] == ride.id.to_s ? nil : ride.id.to_s, tab: @tab),
        data: { turbo_frame: "ride_#{ride.id}_details" },
        class: "block" do %>
      <div class="flex justify-between items-center">
        <div class="flex-1">
          <div class="flex items-center space-x-2">
            <%
              booking = ride.bookings.first

              @pickup_location_text = booking&.pickup
              @dropoff_location_text = booking&.dropoff
            %>

            <span class="text-sm font-medium"><%= @pickup_location_text %></span>

            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>

            <span class="text-sm font-medium"><%= @dropoff_location_text %></span>
          </div>
        </div>

        <div class="flex items-center space-x-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= ride.respond_to?(:status_color) ? ride.status_color : 'bg-gray-100 text-gray-800' %>">
            <%= ride.status.humanize %>
          </span>
          <span class="text-blue-600 font-medium">$<%= sprintf('%.2f', ride.estimated_price || 0) %></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 transform <%= params[:expanded] == ride.id.to_s ? 'rotate-180' : '' %>" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </div>
      </div>
    <% end %>
  </div>

    <% if params[:expanded] == ride.id.to_s %>
      <%
        # Define ride_data hash with safe access to all properties
        @ride_data = {
          id: ride.id,
          pickup_location: @pickup_location_text,
          dropoff_location: @dropoff_location_text,
          scheduled_date: ride.bookings.first&.scheduled_time&.strftime("%A, %B %d, %Y"),
          scheduled_time: ride.bookings.first&.scheduled_time&.strftime("%I:%M %p"),
          estimated_duration: ride.respond_to?(:estimated_duration) ? ride.estimated_duration : 15,
          distance: ride.respond_to?(:distance) && ride.distance ? ride.distance : 12.5,
          estimated_price: ride.estimated_price || 0,
          status: ride.status
        }
      %>

      <%= render partial: "rides/ride_details", locals: { ride: ride, ride_data: @ride_data, expanded: params[:expanded] } %>
    <% end %>
</div>