<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# Profile Section - Left Sidebar %>
  <div class="lg:col-span-1">
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex justify-between items-start mb-4">
        <div>
          
            <div class="w-20 h-20 bg-gray-200 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>

        </div>
        
        <%= link_to edit_user_registration_path, class: "text-blue-600" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
          </svg>
        <% end %>
      </div>
      
      <div class="mb-2">
        <h3 class="font-medium"><%= current_user.full_name %></h3>
        <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          Passenger Profile
        </div>
      </div>
      
      <div class="space-y-2 text-sm">
        <p class="flex items-center">
          <span class="mr-2">Whatsapp:</span>
          <span class="text-gray-600"><%= @passenger_profile&.whatsapp_number || "Not provided" %></span>
        </p>
        <p class="flex items-center">
          <span class="mr-2">Telegram:</span>
          <span class="text-gray-600"><%= @passenger_profile&.telegram_username || "Not provided" %></span>
        </p>
        <p class="flex items-center">
          <span class="mr-2">Email:</span>
          <span class="text-gray-600"><%= current_user.email %></span>
        </p>
      </div>
    </div>
  </div>

  <%# Rides Section - Right Content %>
  <div class="lg:col-span-2">
    <div class="bg-white rounded-lg shadow">
      <div class="p-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-xl font-semibold">My Rides</h2>
          <%= link_to new_booking_path,
              class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-500 flex items-center gap-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
            </svg>
            <span>Book a Ride</span>
          <% end %>
        </div>

        <%# Tabs Navigation - Simplified to just Active and History %>
        <%= render "ride_tabs" %>

        <%= turbo_frame_tag "rides_content" do %>
          <% if params[:tab] == "history" %>
            <%= render "ride_history", history_rides: @history_rides %>
          <% else %>
            <%= render "active_rides", active_rides: @active_rides %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

