<div class="border-b border-gray-200">
  <nav class="flex" aria-label="Tabs">
    <%= link_to dashboard_rides_path(tab: "active"),
        class: "whitespace-nowrap px-4 py-2 text-sm font-medium border-b-2 #{params[:tab] != 'history' ? 'text-blue-600 border-blue-600' : 'text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-300'}",
        data: { turbo_frame: "rides_content" } do %>
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
          <path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3z"/>
        </svg>
        Active Ride
      </span>
    <% end %>

    <%= link_to dashboard_rides_path(tab: "history"),
        class: "whitespace-nowrap px-4 py-2 text-sm font-medium border-b-2 #{params[:tab] == 'history' ? 'text-blue-600 border-blue-600' : 'text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-300'}",
        data: { turbo_frame: "rides_content" } do %>
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
        </svg>
        History
      </span>
    <% end %>
  </nav>
</div> 