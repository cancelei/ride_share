<div class="container mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-6">Welcome, <%= current_user.first_name %></h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- User profile card -->
    <div class="bg-white rounded-lg shadow p-6">
      <!-- Your existing profile card content -->
    </div>

    <!-- Rides section -->
    <div class="md:col-span-2 bg-white rounded-lg shadow">
      <div class="p-6">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-semibold">My Rides</h2>
          <%= link_to "Book a Ride", new_booking_path,
              class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700" %>
        </div>

        <%= render "ride_tabs" %>

        <%= turbo_frame_tag "rides_content" do %>
          <% if @tab == "history" %>
            <%= render "ride_history", history_rides: @history_rides %>
          <% else %>
            <%= render "active_rides", active_rides: @active_rides, my_bookings: @my_bookings %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>